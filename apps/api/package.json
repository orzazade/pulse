    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/typeorm": "^10.0.0",
    "@pulse/shared": "workspace:*",
    "bull": "^4.16.0",
    "class-transformer": "^0.5.1",
